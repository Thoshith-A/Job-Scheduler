# ─────────────────────────────────────────────────────────────────────────────
# Flux Scheduler — environment. Copy to `.env` and adjust.
# Every service reads from here. Nothing secret is committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── PostgreSQL (the queue lives here) ────────────────────────────────────────
# docker-compose sets this automatically. For the no-Docker local path,
# `pnpm stack:local` boots an embedded Postgres and injects this for you.
DATABASE_URL=postgres://flux:flux@localhost:5432/flux
# Pool sizing per service (workers need enough for their concurrency + heartbeat)
DB_POOL_MAX=20

# ── Redis (rate limiting, distributed locks, pub/sub — NOT the queue core) ────
# Optional. If unset, services fall back to in-memory implementations so the
# whole system runs with zero external dependencies. docker-compose sets it.
REDIS_URL=redis://localhost:6379

# ── API service ──────────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# ── Auth (generate real secrets: `openssl rand -base64 48`) ───────────────────
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Scheduler service ─────────────────────────────────────────────────────────
SCHEDULER_TICK_MS=1000
# Enable Redis-backed leader lock so multiple scheduler replicas don't double-promote.
SCHEDULER_SINGLETON_LOCK=true

# ── Worker service ────────────────────────────────────────────────────────────
WORKER_ID=
WORKER_POLL_MS=500
WORKER_HEARTBEAT_MS=5000
# Lease each claimed job holds; the reaper reclaims jobs whose lease expires.
WORKER_LEASE_SECONDS=30
# Max jobs a single worker process executes concurrently (per-queue limits also apply).
WORKER_MAX_CONCURRENCY=10

# ── AI failure summaries (bonus) ─────────────────────────────────────────────
# If unset, the endpoint returns a deterministic heuristic summary instead.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Web dashboard ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
