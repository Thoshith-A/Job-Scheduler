    "@flux/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "embedded-postgres": "18.4.0-beta.17",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
